from abc import ABC, abstractmethod
from typing import Any, Literal


class AbstractDataset(ABC):
    """
    A single, unified data I/O object.
    Supports incremental loading/saving, querying, and multiple dataframe formats.
    """

    @abstractmethod
    def __init__(
        self, path: str, versioned: bool = False, **kwargs: Any
    ):
        self.path = path
        self.versioned = versioned
        self.kwargs = kwargs


    @abstractmethod
    def load(self, **kwargs: Any) -> Any:
        """Load the dataset into memory."""
        raise NotImplementedError(
            "Storage engines will be implemented in a future phase."
        )

    @abstractmethod
    def save(
        self,
        data: Any,
        mode: Literal["overwrite", "append"] = "overwrite",
        **kwargs: Any,
    ) -> None:
        """Save the dataset to storage."""
        raise NotImplementedError(
            "Storage engines will be implemented in a future phase."
        )

    @abstractmethod
    def exists(self) -> bool:
        """Check if the dataset exists in storage."""
        raise NotImplementedError(
            "Storage engines will be implemented in a future phase."
        )

